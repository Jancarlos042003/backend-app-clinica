spring:
  datasource:
    url: jdbc:mysql://localhost:3306/postalta_db?useSSL=false&serverTimezone=UTC
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: DEV_USER
    password: DEV_PASSWORD
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
        properties:
          hibernate:
            dialect: org.hibernate.dialect.MySQL8Dialect
            format_sql: true

server:
  port: 8080
